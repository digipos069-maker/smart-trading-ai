DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/smart_trading_ai
AUTO_CREATE_TABLES=true

# Optional explicit MetaTrader 5 connection settings.
# Keep real credentials in backend/.env, never commit them.
MT5_LOGIN=12345678
MT5_PASSWORD=your_password
MT5_SERVER=YourBroker-Server
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_FORCE_LOGIN=false
MT5_TIMEOUT_MS=60000

OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=20
