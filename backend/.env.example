DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/smart_trading_ai
AUTO_CREATE_TABLES=true
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
MARKET_DATA_PROVIDER=mt5
MARKET_DATA_TIMEOUT_SECONDS=15
BINANCE_BASE_URL=https://api.binance.com
OANDA_BASE_URL=https://api-fxpractice.oanda.com
OANDA_API_TOKEN=your_oanda_token

# Optional explicit MetaTrader 5 connection settings.
# Keep real credentials in backend/.env, never commit them.
MT5_LOGIN=12345678
MT5_PASSWORD=your_password
MT5_SERVER=YourBroker-Server
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_FORCE_LOGIN=false
MT5_TIMEOUT_MS=60000

OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=20

MARKET_DATA_SERVICE_URL=http://127.0.0.1:8010
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
SIGNAL_ALERTS_ENABLED=false
SIGNAL_ALERT_SYMBOLS=XAUUSD
SIGNAL_ALERT_TIMEFRAMES=M5
SIGNAL_ALERT_INTERVAL_SECONDS=300
SIGNAL_ALERT_MIN_SCORE=75
SIGNAL_ALERT_CANDLE_LIMIT=500
SIGNAL_ALERT_SYNC_PROVIDER=mt5

# MT5 execution guardrails. Keep disabled until demo forward testing is stable.
TRADING_ENABLED=false
TRADING_MODE=demo
AUTO_EXECUTE_SIGNALS=false
EXECUTION_MIN_SCORE=75
EXECUTION_RISK_PERCENT=1
EXECUTION_MAX_RISK_PERCENT=2
EXECUTION_DEVIATION_POINTS=20
EXECUTION_MAGIC_NUMBER=20260620
